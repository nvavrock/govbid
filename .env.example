# PostgreSQL
POSTGRES_USER=govbid
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=govbid
# Host/port for local tools (Python CLI, psql from host). Docker services use hostname "postgres".
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# n8n UI (basic auth) and credential encryption (32+ chars, required)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
# Owner UI sign-in (not the admin username above)
N8N_OWNER_EMAIL=you@example.com
# Generate once and keep stable (changing it requires reset-n8n-volume.sh):
# openssl rand -hex 16
N8N_ENCRYPTION_KEY=change_me_32_char_encryption_key

# SAM.gov — get key at https://sam.gov → Account Details
SAM_API_KEY=

# Latest bulk CSV URL from SAM Data Services (copy when it changes):
# https://sam.gov/data-services/Contract%20Opportunities?privacy=Public
SAM_BULK_CSV_URL=https://sam.gov/api/prod/fileextractservices/v1/api/download/Contract%20Opportunities/datagov/ContractOpportunitiesFullCSV.csv?privacy=Public

# Optional host cron schedule for scripts/install_daily_cron.sh (default: 0 6 * * *)
# GOVBID_DAILY_CRON=0 6 * * *

# Software NAICS codes (comma-separated) for API delta workflow
SAM_NAICS_CODES=541511,541512,541519,518210,511210

# Consig (OpenAI RAG + capture copilot)
OPENAI_API_KEY=
CONSIG_LLM_MODEL=gpt-4o-mini
CONSIG_EMBEDDING_MODEL=text-embedding-3-small
CONSIG_DATA_DIR=data/consig_index
CONSIG_API_URL=http://127.0.0.1:8000
CONSIG_TOP_K=6
