# Cursor debug sessions
.cursor/debug-*.log

# WSL/Windows metadata
*:Zone.Identifier

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/.terraform.lock.hcl
terraform/terraform.tfvars

# Secrets and local config
.env
config/match-profile.yaml

# Python
.venv/
__pycache__/
*.pyc
*.pyo
node_modules/

# Counsel vector index (rebuilt by scripts/build_counsel_index.py)
data/counsel_index/

# SAM data (large; refreshed by run_download.sh or n8n ingest)
data/*.csv
!data/.gitkeep
!data/state-imports/
!data/state-imports/.gitkeep

# Logs and runtime locks
logs/*
!logs/.gitkeep

# Proprietary transcript data (local only)
transcripts/

# User-space PostgreSQL (scripts/setup_user_postgres.sh)
.postgres/
bin/micromamba

# Docker / misc
.DS_Store

# Excel
*.xlsx
