# WSL/Windows metadata
*:Zone.Identifier

# Python
.venv/
__pycache__/
*.pyc
*.pyo
# SAM data (large; refreshed by run_download.sh)
data/*.csv
!data/.gitkeep

# Logs and runtime locks
logs/*
!logs/.gitkeep

# GovClose fetch artifacts (regenerated locally)
transcripts/govclose/*.vtt
transcripts/govclose/.archive.txt
transcripts/govclose/*.en-en.txt

# Per-video corpus is tracked intentionally (.txt, .info.json, govclose_all.txt)
